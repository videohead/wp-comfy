        "sampler_name": "euler",
        "scheduler": "normal",
        "denoise": 1.0,
        "model": ["__MODEL_REF__"],
        "positive": ["2", 0],
        "negative": ["3", 0],
        "latent_image": ["4", 0],
        "motion_bucket_id": "__MOTION_BUCKET_ID__",
        "fusion_beta": "__FUSION_BETA__"
      },
      "class_type": "KSamplerAdvanced",
      "_meta": {
        "title": "KSampler Advanced (I2V)"
      }
    },
    "6": {
      "inputs": {
