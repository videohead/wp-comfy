      }
    },
    "7": {
      "inputs": {
        "images": ["6", 0],
        "fps": "__FPS__",
        "format": "video/h264-mp4",
        "method": "secure",
        "filename_prefix": "__OUTPUT_FILENAME_PREFIX__"
      },
      "class_type": "SaveImage",
      "_meta": {
        "title": "Save Video Output"
      }
    }
  }
}
