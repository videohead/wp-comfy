        "title": "Negative Prompt"
      }
    },
    "4": {
      "inputs": {
        "image_path": "__POSE_IMAGE_PATH__",
        "latents_size": "LTX-2.3"
      },
      "class_type": "LoadImageForVideo",
      "_meta": {
        "title": "Load Reference Image"
      }
    },
    "5": {
      "inputs": {
        "seed": "__SEED__",
